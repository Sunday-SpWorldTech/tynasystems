<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Tyna Systems | Join Free</title><link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet"><style>*{box-sizing:border-box;font-family:'Poppins',sans-serif}body.auth{display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#141e30,#243b55);min-height:100vh;margin:0;padding:20px}.card{background:#23aa8b;padding:2.5rem 2rem;border-radius:18px;max-width:430px;width:100%;text-align:center;box-shadow:0 25px 50px rgba(44,13,220,.4);animation:slideUp .8s ease}.card h2{color:#f0b90b;margin:0 0 .5rem;font-size:1.85rem}.card p{color:#e7e7e7;margin:0 0 1.35rem;font-size:.92rem}.brand-link{display:inline-flex;align-items:center;gap:10px;color:#fff;text-decoration:none;margin-bottom:12px;font-weight:700}.brand-dot{width:36px;height:36px;border-radius:12px;background:#f0b90b;color:#1e2329;display:grid;place-items:center;font-weight:800}input{width:100%;padding:12px 15px;margin-bottom:15px;border-radius:10px;border:1px solid rgba(255,255,255,.25);background:rgba(0,0,0,.18);color:#fff;outline:none}input::placeholder{color:rgba(255,255,255,.75)}button,.button-link{width:100%;padding:12px;border:none;border-radius:14px;background:#f0b90b;color:#1e2329;font-weight:700;cursor:pointer;transition:.2s;font-size:1rem;margin-bottom:10px;text-decoration:none;display:block}button:disabled{opacity:.7;cursor:not-allowed}button:hover:not(:disabled),.button-link:hover{transform:translateY(-2px);box-shadow:0 12px 25px rgba(240,185,11,.35)}.google-btn{background:linear-gradient(135deg,#4285f4,#1a73e8);color:#fff}.signup-btn{background:linear-gradient(135deg,#780000,#c1121f);color:#fff;margin-top:8px}.footer-text,.switch-text{margin-top:1rem;font-size:.86rem;color:rgba(255,255,255,.88)}.switch-text a{color:#0b1b2a;text-decoration:none;font-weight:800}.switch-text a:hover{text-decoration:underline}.toast{position:fixed;top:20px;right:20px;background:#0f2027;color:#fff;padding:14px 18px;border-radius:10px;z-index:9999;box-shadow:0 10px 25px rgba(0,0,0,.3);max-width:320px}.toast.success{border-left:5px solid #22c55e}.toast.error{border-left:5px solid #ef4444}.toast.info{border-left:5px solid #38bdf8}@keyframes slideUp{from{opacity:0;transform:translateY(25px)}to{opacity:1;transform:translateY(0)}}@media(max-width:480px){.card{padding:2rem 1.2rem}}</style></head><body class="auth" data-app-page="auth"><div class="card"><a class="brand-link" href="index.html"><span class="brand-dot">T</span><span>Tyna Systems</span></a><h2>Join Free</h2><p>Create your secure account and continue to your dashboard.</p><form data-joinfree-form autocomplete="on"><input type="text" name="name" placeholder="Full Name" autocomplete="name" required><input type="email" name="email" placeholder="Email Address" autocomplete="email" required><input type="text" name="company" placeholder="Company Name (optional)" autocomplete="organization"><input type="password" name="password" placeholder="Password - minimum 8 characters" autocomplete="new-password" minlength="8" required><button type="submit" class="signup-btn">Join Free</button><div data-form-message class="toast hidden"></div></form><button type="button" class="google-btn" onclick="toast('Google sign-in needs GOOGLE_CLIENT_ID configured in .env.', 'info')">Continue with Google</button><a class="button-link" href="login.html">Login</a><div class="switch-text">Already have an account? <a href="login.html">Login</a></div><div class="footer-text">Tip: Google login doesn’t need password · Secured</div></div><script>function toast(msg,type='info'){const t=document.createElement('div');t.className=`toast ${type}`;t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),3500)}</script><script src="assets/js/app.js"></script></body></html>