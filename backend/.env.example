PORT=5000
NODE_ENV=production
NODE_VERSION=20

# Frontend URLs allowed by CORS
CLIENT_URL=https://tynasystems-frontend.onrender.com
FRONTEND_URaL=https://tynasystems-frontend.onrender.com
CORS_ORIGINS=https://tynasystems-frontend.onrender.com,http://localhost:5173,http://127.0.0.1:5173

# Database and auth
MONGODB_URI=mongodb+srv://TynaSystemsApp:wzBmsSuTiRIjUh0O@tynasystemsapp.qoc1hrv.mongodb.net/tynasystems?retryWrites=true&w=majority&appName=TynaSystemsApp
JWT_SECRET=replace_with_a_long_random_secret_from_node_crypto

# Staff login
STAFF_USERNAME=Tyna
STAFF_EMAIL=staff@tynasystems.com
STAFF_PASSWORD=Systems

# Google login
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Paystack. Never expose the secret key in frontend.
PAYSTACK_SECRET_KEY=sk_test_replace_with_your_real_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_replace_with_your_real_public_key
PAYSTACK_CALLBACK_URL=https://tynasystems-frontend.onrender.com/demo-checkout.html

# Optional SMTP settings for Join Free/login email alerts
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@tynasystems.com
SMTP_PASS=replace_with_smtp_password
EMAIL_FROM=Tyna Systems <no-reply@tynasystems.com>
EMAIL_FROM_NAME=Tyna Systems
